# --- Mailbox (via ProtonMail Bridge on localhost, or any IMAP server) ---
IMAP_HOST=127.0.0.1
IMAP_PORT=1143
IMAP_USER=you@example.com
IMAP_PASS=your-bridge-or-app-password
SMTP_HOST=127.0.0.1
SMTP_PORT=1025
# Bridge speaks STARTTLS with a SELF-SIGNED cert on localhost, so verification
# is off here. If you point at a real provider (Gmail etc), set TLS_VERIFY=true.
# Never run TLS_VERIFY=false against anything that is not 127.0.0.1.
TLS_VERIFY=false
# Implicit TLS (port 993 style, Gmail/most providers) instead of STARTTLS
IMAP_SSL=false

# --- What counts as a print job ---
# The address people email to print. With Proton this is an alias on your
# account; with Gmail use you+print@gmail.com and a filter.
PRINT_TO=print@example.com
# Comma-separated. EMPTY LIST = NOTHING PRINTS (fail-closed on purpose).
ALLOWED_SENDERS=spouse@example.com,kid1@example.com
# IMAP folder the poller watches. Use a filter/sieve rule to route PRINT_TO
# mail here so the poller never touches your real inbox.
SOURCE_FOLDER=Folders/print

# --- Printer ---
# CUPS queue name on the host: `lpstat -p` to list them
PRINTER=Your_Printer_Queue
CUPS_SERVER=127.0.0.1:631
# lp options. MEDIA=a4 outside the US; SIDES=two-sided-long-edge for duplex.
MEDIA=letter
SIDES=one-sided

# --- Behavior ---
PROCESSED_FOLDER=Folders/Printed
REJECTED_FOLDER=Folders/Print-Rejected
POLL_INTERVAL=60
MAX_ATTACH_MB=25
# Email the sender a printed/failed status (allowlisted senders only)
CONFIRM_REPLY=true
# Also reply to rejected non-allowlisted senders. Off by default: their From
# address is unverified, and replying to spoofed mail is how you make backscatter.
REPLY_ON_REJECT=false
# If the email has no printable attachment, render and print the body itself
PRINT_BODY=true
# Extra hardening: also require SPF or DKIM pass in Authentication-Results
REQUIRE_AUTH_PASS=false
# Health endpoint bind. Keep on localhost unless your monitoring lives elsewhere.
HEALTH_BIND=127.0.0.1
# Log what would print without printing
DRY_RUN=false
